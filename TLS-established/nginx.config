server {

    server_name app.ranaequator.club;

    location / {
        proxy_pass  http://localhost:30371/;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/app.ranaequator.club/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/app.ranaequator.club/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = app.ranaequator.club) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;

    server_name app.ranaequator.club;
    return 404; # managed by Certbot


}